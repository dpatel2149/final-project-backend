{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "esnext",
    "types": ["node", "jest"],
    "sourceMap": true,
    "declaration": false,
    "strict": false,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  }
}
